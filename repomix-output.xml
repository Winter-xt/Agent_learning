//            for (int i = 1; i < lines.size(); i++) {
//                String line = lines.get(i).trim();
//                if (!line.isEmpty()) {
//                    TextSegment segment = TextSegment.from(line);
//                    embeddingStore.add(embeddingModel.embed(segment).content(), segment);
